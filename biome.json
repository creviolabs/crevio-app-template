{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"root": "."
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/package.json",
			"!**/bun.lockb",
			"!**/components/ui",
			"!**/hooks/use-mobile.ts",
			"!**/*.css",
			"!cloudflare-env.d.ts",
			"!worker-configuration.d.ts",
			"!.*"
		]
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui/**"],
			"linter": { "enabled": false }
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
