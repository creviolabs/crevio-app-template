{
	"name": "crevio-app-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "bun run check:forms && bun run check:bookings && vinext build",
		"check:forms": "bun scripts/check-form-ids.ts",
		"check:bookings": "bun scripts/check-event-type-ids.ts",
		"cf-typegen": "wrangler types",
		"deploy": "vinext deploy",
		"dev": "vp dev",
		"start": "vinext start",
		"postinstall": "bun run cf-typegen",
		"typecheck": "bun run cf-typegen && tsgo -b",
		"check": "biome check --write --unsafe .",
		"test": "bun test"
	},
	"dependencies": {
